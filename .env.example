INTERVALS_API_KEY=
INTERVALS_ATHLETE_ID=
CLAUDE_API_KEY=
LOCAL_TIMEZONE=Australia/Melbourne
PLANS_DIR=./plans
JEZR_DB_PATH=./data/jezr.db
JEZR_BACKUP_DIR=./backups
JEZR_BACKUP_RETAIN_WEEKS=4

# OpenClaw notifier settings
JEZR_NOTIFIER=openclaw
JEZR_OPENCLAW_TARGET=+61430220917   # Phone number to send WhatsApp messages to
JEZR_OPENCLAW_CHANNEL=whatsapp      # Channel to use (default: whatsapp)
# JEZR_OPENCLAW_BIN=/home/funk44/.npm-global/bin/openclaw  # Optional: full path if openclaw is not on PATH

# Default location for weather enrichment when activity has no coordinates
# (Intervals.icu does not return lat/lng — set this to your home city)
JEZR_DEFAULT_LAT=-37.8136
JEZR_DEFAULT_LNG=144.9631
